From 1fe1f021f7ae3288bfe446a3d503a754df21e78d Mon Sep 17 00:00:00 2001
From: Darxfame <eivinfd15111992@hotmail.com>
Date: Thu, 28 May 2026 16:21:39 +0000
Subject: [PATCH] feat(auth): account recovery via encrypted key backup +
 Ed25519 challenge-response
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Adds three new endpoints to support secure account recovery without
server-side key escrow:

  POST /auth/key-backup
    Stores an AES-256-GCM encrypted private key bundle uploaded by the
    client after registration. The blob is encrypted client-side with a
    key derived from the user's 24-word recovery mnemonic (PBKDF2-SHA256,
    600k iterations). The server stores it verbatim and never decrypts it.
    Requires a valid JWT.

  POST /auth/recover/challenge
    Public endpoint (no JWT). Issues a one-time 64-hex-char nonce for
    the given UIN, stored in Redis with a 5-minute TTL. The client must
    sign it with their Ed25519 signing key within the TTL.

  POST /auth/recover/verify
    Public endpoint. Verifies the Ed25519 signature of the challenge
    against the stored PUBLIC signing_key. On success: consumes the
    challenge (one-time use), returns a fresh JWT and the encrypted_blob
    for the client to re-import on the new device.

Also adds encrypted_key_blob (TEXT, nullable) to the users table.
The column is NULL for users who have not yet uploaded a backup —
recovery will still authenticate them (new JWT) but won't return a
blob to restore Signal keys on the new device.

Security model:
  - Server stores: public keys (identity_key, signing_key), encrypted blob
  - Server NEVER sees: private keys, mnemonic, AES key
  - Blob theft without mnemonic: infeasible (PBKDF2 600k + AES-256-GCM)
  - Challenge replay after verify: blocked (Redis key deleted on use)
---
 app/models/user.py  |   6 ++
 app/routers/auth.py | 141 ++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 147 insertions(+)

diff --git a/app/models/user.py b/app/models/user.py
index dd5e0ae..0027079 100644
--- a/app/models/user.py
+++ b/app/models/user.py
@@ -19,6 +19,12 @@ class User(Base):
     # carried inside the encrypted payload (sealed-sender style) and verified
     # by the recipient against the value the server reports here.
     signing_key: Mapped[str] = mapped_column(Text)
+    # AES-256-GCM encrypted private key bundle, base64. NULL until the client
+    # calls POST /auth/key-backup. Encrypted client-side with a key derived
+    # from the user's 24-word recovery mnemonic via PBKDF2-SHA256 (600k iter).
+    # The server stores this opaque blob verbatim and returns it during account
+    # recovery (POST /auth/recover/verify). The server never sees plaintext keys.
+    encrypted_key_blob: Mapped[str | None] = mapped_column(Text, nullable=True)
 
     # ── Stage 3 libsignal material (additive on top of the Stage 2 keys above).
     # NULL until the user upgrades to a Stage 3 client and uploads a key bundle
diff --git a/app/routers/auth.py b/app/routers/auth.py
index 900c0d6..1b978e0 100644
--- a/app/routers/auth.py
+++ b/app/routers/auth.py
@@ -180,3 +180,144 @@ async def delete_account(
 
     await db.delete(user)
     await db.commit()
+
+
+# ── Account Recovery ──────────────────────────────────────────────────────────
+import base64
+import secrets
+
+from cryptography.exceptions import InvalidSignature
+from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PublicKey
+from redis.asyncio import Redis
+
+from app.core.redis import get_redis
+
+_CHALLENGE_KEY = "recover:challenge:{uin}"
+_CHALLENGE_TTL = 300  # 5 min — client must sign within this window
+
+
+class KeyBackupIn(BaseModel):
+    encrypted_blob: str  # AES-256-GCM ciphertext of private keys, base64
+
+
+class RecoverChallengeIn(BaseModel):
+    uin: int
+
+
+class RecoverChallengeOut(BaseModel):
+    challenge: str  # 64 hex chars, one-time, TTL 5 min
+
+
+class RecoverVerifyIn(BaseModel):
+    uin: int
+    challenge: str
+    signature: str  # base64( Ed25519.sign(challenge.encode("utf-8")) )
+
+
+class RecoverVerifyOut(BaseModel):
+    token: str
+    encrypted_blob: str | None
+
+
+@router.post("/key-backup", status_code=status.HTTP_204_NO_CONTENT)
+async def save_key_backup(
+    body: KeyBackupIn,
+    uin: int = Depends(current_uin),
+    db: AsyncSession = Depends(get_db),
+) -> None:
+    """Store the client-encrypted private key blob. Requires a valid JWT.
+
+    Called once after registration with an AES-256-GCM ciphertext of the
+    user's private key bundle, encrypted client-side from their 24-word
+    recovery mnemonic via PBKDF2-SHA256 (600k iterations). Safe to call
+    again to rotate the blob after a mnemonic refresh.
+
+    The server stores the blob verbatim and never decrypts it.
+    """
+    user = await db.get(User, uin)
+    if user is None:
+        raise HTTPException(status.HTTP_404_NOT_FOUND, "user not found")
+    user.encrypted_key_blob = body.encrypted_blob
+    await db.commit()
+
+
+@router.post("/recover/challenge", response_model=RecoverChallengeOut)
+async def recover_challenge(
+    body: RecoverChallengeIn,
+    db: AsyncSession = Depends(get_db),
+    redis: Redis = Depends(get_redis),
+) -> RecoverChallengeOut:
+    """Issue a one-time challenge nonce for account recovery.
+
+    Public endpoint — no JWT required. Returns a 64-hex-char random nonce
+    stored in Redis with a 5-minute TTL. The client must sign it with their
+    Ed25519 signing key (restored from the 24-word mnemonic) and POST the
+    signature to /auth/recover/verify within the TTL.
+
+    Returns 404 if the UIN is unknown — safe to expose since UINs are not
+    secrets (they appear in public message metadata).
+    """
+    user = await db.scalar(select(User).where(User.uin == body.uin))
+    if user is None:
+        raise HTTPException(status.HTTP_404_NOT_FOUND, "user not found")
+    challenge = secrets.token_hex(32)
+    await redis.set(
+        _CHALLENGE_KEY.format(uin=body.uin), challenge, ex=_CHALLENGE_TTL
+    )
+    return RecoverChallengeOut(challenge=challenge)
+
+
+@router.post("/recover/verify", response_model=RecoverVerifyOut)
+async def recover_verify(
+    body: RecoverVerifyIn,
+    db: AsyncSession = Depends(get_db),
+    redis: Redis = Depends(get_redis),
+) -> RecoverVerifyOut:
+    """Verify Ed25519 challenge signature and return a fresh JWT + key blob.
+
+    Full client flow:
+      1. POST /auth/recover/challenge  →  receive nonce
+      2. Derive AES key from 24-word mnemonic (PBKDF2-SHA256, 600k iter)
+      3. AES-GCM decrypt the locally-stored encrypted signing key
+      4. Ed25519-sign the nonce bytes with the restored signing_key_private
+      5. POST { uin, challenge, base64(signature) } to this endpoint
+      6. Receive { token, encrypted_blob }:
+           - token: fresh JWT for immediate use
+           - encrypted_blob: the full private key bundle stored at registration;
+             AES-GCM decrypt it with the same mnemonic-derived key to restore
+             the complete identity on the new device
+
+    Security properties:
+      - The server only stores the PUBLIC signing_key, never the private half.
+      - The challenge is one-time-use; replaying it after verify returns 401.
+      - The encrypted_blob is opaque to the server — it cannot read private keys.
+      - An attacker who steals the blob from the DB cannot decrypt it without
+        the 24-word mnemonic (PBKDF2 with 600k iterations makes brute-force
+        infeasible for any mnemonic with sufficient entropy).
+    """
+    # 1. Verify the challenge exists and hasn't expired or been used already
+    stored = await redis.get(_CHALLENGE_KEY.format(uin=body.uin))
+    if stored is None or stored != body.challenge:
+        raise HTTPException(status.HTTP_401_UNAUTHORIZED, "invalid or expired challenge")
+
+    # 2. Load user — must exist to have a signing_key to verify against
+    user = await db.scalar(select(User).where(User.uin == body.uin))
+    if user is None:
+        raise HTTPException(status.HTTP_404_NOT_FOUND, "user not found")
+
+    # 3. Verify Ed25519 signature against the stored PUBLIC signing_key
+    try:
+        pub_bytes = base64.b64decode(user.signing_key)
+        public_key = Ed25519PublicKey.from_public_bytes(pub_bytes)
+        sig_bytes = base64.b64decode(body.signature)
+        public_key.verify(sig_bytes, body.challenge.encode("utf-8"))
+    except (InvalidSignature, Exception):
+        raise HTTPException(status.HTTP_401_UNAUTHORIZED, "signature verification failed")
+
+    # 4. Consume challenge — one-time use prevents replay attacks
+    await redis.delete(_CHALLENGE_KEY.format(uin=body.uin))
+
+    return RecoverVerifyOut(
+        token=issue_token(body.uin),
+        encrypted_blob=user.encrypted_key_blob,
+    )
